/*
Problem: 202. Happy Number
*/

class Solution {

    public static int check(int n){
        int sq = 0;
        while(n > 0){
            int temp = n % 10;
            sq += temp * temp;
            n /= 10;
        }
        return sq;
    }

    public boolean isHappy(int n) {

        boolean ans = false;

        if(n == 1 || n == 7){
            ans = true;
        }
        else if(n >= 0 && n <= 9){
            ans = false;
        }
        else if(n < 0){
            ans = false;
        }
        else {
            while(n != 1 && n != 4){
                n = check(n);
            }

            if(n == 1){
                ans = true;
            } else {
                ans = false;
            }
        }

        return ans;
    }
}
