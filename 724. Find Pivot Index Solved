724. Find Pivot Index
class Solution {
    public int pivotIndex(int[] nums) {
        int total=0,left=0;
        int index=-1;
        for(int i=0;i<nums.length;i++){
            total+=nums[i];
        }
       for(int i=0;i<nums.length;i++){
        total-=nums[i];
        if(left==total){
            index=i;
            return index;
        }
        left+=nums[i];
       }
    
          return index;  

    }
}
