/*
Problem: 345. Reverse Vowels of a String


*/

class Solution {
    public String reverseVowels(String b) {

        int n = b.length();

        int l = 0, r = n - 1;

        String rev = "aeiouAEIOU";
        char ch[] = b.toCharArray();

        while (l < r) {

            if (rev.indexOf(ch[l]) == -1) {
                l++;
            }
            else if (rev.indexOf(ch[r]) == -1) {
                r--;
            }
            else {

                char er = b.charAt(l);

                ch[l] = ch[r];
                ch[r] = er;

                l++;
                r--;
            }
        }

        return new String(ch);
    }
}
