/*
Problem: 1295. Find Numbers with Even Number of Digits


*/

class Solution {
    public int findNumbers(int[] nums) {
        int c = 0;

        for (int i : nums) {

            int d = 0;

            while (i > 0) {
                d++;
                i /= 10;
            }

            if (d % 2 == 0) {
                c++;
            }
        }

        return c;
    }
}
