34. Find First and Last Position of Element in Sorted Array


class Solution {
    public int[] searchRange(int[] nums, int target) {
    
        int arr[]=new int[2];
        arr[0]=find(nums,target,true);
        arr[1]=find(nums,target,false);
   return arr;
    }
    public int find(int nums[],int t,boolean flag){
          int l=0,h=nums.length-1,res=-1;
        while(l<=h){
            int  mid=l+(h-l)/2;
           if(nums[mid]==t){
            res=mid;
                if(flag) {
                  h=mid-1;
                }
                else {
                    l=mid+1;
                    }
                    
                   
            }else if(nums[mid]<t){
                l=mid+1;
            }else {
                          h=mid-1;
            }
        }
    return res;
    }

}
