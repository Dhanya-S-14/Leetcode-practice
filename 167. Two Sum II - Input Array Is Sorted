/*
Problem: 167. Two Sum II - Input Array Is Sorted
*/

class Solution {
    public int[] twoSum(int[] num, int target) {

        int l = 0;
        int r = num.length - 1;

        while (l < r) {

            int cs = num[l] + num[r];

            if (cs == target) {
                return new int[]{l + 1, r + 1};
            }
            else if (cs < target) {
                l++;
            }
            else {
                r--;
            }
        }

        return new int[]{-1, -1};
    }
}
