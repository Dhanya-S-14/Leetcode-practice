/*
Problem: 2108. Find First Palindromic String in the Array
*/

class Solution {

    public String firstPalindrome(String[] words) {

        for (int i = 0; i < words.length; i++) {

            String first = words[i];

            int j = 0;
            int k = first.length() - 1;

            boolean flag = true;

            while (j < k) {

                if (first.charAt(j) != first.charAt(k)) {
                    flag = false;
                    break;
                }

                j++;
                k--;
            }

            if (flag) {
                return first;
            }
        }

        return "";
    }
}
