
//Problem: 151. Reverse Words in a String

class Solution {

    public String reverseWords(String s) {

        String arr[] = s.trim().split("\\s+");

        int i = 0;
        int j = arr.length - 1;

        while (i < j) {

            String a = arr[i];
            arr[i] = arr[j];
            arr[j] = a;

            i++;
            j--;
        }

        String ans = String.join(" ", arr);

        return ans;
    }
}
