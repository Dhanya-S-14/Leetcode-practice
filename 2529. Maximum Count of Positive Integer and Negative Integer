/*
Problem: 2529. Maximum Count of Positive Integer and Negative Integer


*/

class Solution {
    public int maximumCount(int[] nums) {

        int cn = 0, c = 0;

        for (int num : nums) {

            if (num < 0) {
                cn++;
            }
            else if (num == 0) {
                continue;
            }
            else {
                c++;
            }
        }

        int ans = Math.max(c, cn);
        return ans;
    }
}
