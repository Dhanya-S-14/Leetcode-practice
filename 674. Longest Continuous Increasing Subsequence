674. Longest Continuous Increasing Subsequence

class Solution {
    public int findLengthOfLCIS(int[] arr) {
        int max=1;
        int c=1;
        for(int i=0;i<arr.length-1;i++){
            if(arr[i]<arr[i+1]){
                c++;
                
             } else{
                c=1;
            }
            if(c>max){
                    max=c;
                }
        }
        return max;
    }
}
